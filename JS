// Pega o elemento do visor do HTML para mexer nele
const visor = document.getElementById('visor');

// Função para quando o usuário clicar em um número
function digitar(numero) {
    // Adiciona o número clicado ao final do que já está no visor
    visor.value = visor.value + numero;
}

// Função para quando clicar nos operadores (+, -, *, /)
function definirOperacao(operador) {
    // Adiciona o operador no visor
    visor.value = visor.value + operador;
}

// Função para limpar o visor (Botão C)
function limpar() {
    visor.value = '';
}

// Função que faz a conta (Botão =)
function calcular() {
    try {
        // O eval() pega o texto do visor (ex: "7+8") e calcula o resultado real
        visor.value = eval(visor.value);
    } catch (error) {
        // Se o usuário digitar algo errado (ex: "++7"), mostra erro
        visor.value = 'Erro';
    }
}

function apagarUltimo() {
    // O slice(0, -1) significa: "pegue do começo do texto até a penúltima letra"
    visor.value = visor.value.slice(0, -1);
}
